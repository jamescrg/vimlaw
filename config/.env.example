# Generate secret key on site: https://djecrety.ir/
SECRET_KEY=[string]

# Always set DEBUG to False in production
DEBUG=[boolean]

# Environment of the deployed application (dev, staging, prod..)
ENV=[string]

# Comma separated list of hosts where the application is allowed to run, example:
ALLOWED_HOSTS='127.0.0.1,localhost'

# Name of the site
SITE_NAME=[string]

# Database settings
DB_NAME=[string]
DB_USER=[string]
DB_PASSWORD=[string]

# Admins that will receive error emails, needs to be a list of tuples, example:
ADMINS="[('John Doe', 'john@mail.com')]"

# Email settings
EMAIL_HOST=[string]
EMAIL_HOST_USER=[string]
EMAIL_HOST_PASSWORD=[string]
SERVER_EMAIL=[string]
# Address(es) BCC'd on every invoice email, so the firm keeps a copy of what was
# sent. Comma-separated; leave unset to disable.
INVOICE_SEND_BCC=archive@example.com

# ID of the Google Calendar where events will be created
CALENDAR_ID=[string]

# Google Drive case-notes sync (optional — defaults shown)
# Root Drive folder whose <matter>/Notes/** files are synced into Note records
DRIVE_NOTES_ROOT=Matters - Open
# Opt-in debug mirror: if set, also write converted Markdown to this dir for
# inspection (canonical storage is the database). Leave blank to disable.
DRIVE_NOTES_DEBUG_DIR=
# Set only if "Matters - Open" lives in a Shared Drive (otherwise leave blank)
DRIVE_SHARED_DRIVE_ID=

# ID of the law firm, used in the LEDES invoice
LAW_FIRM_ID=[string]

ANTHROPIC_API_KEY=[string]
GEMINI_API_KEY=[string]

# LawPay / AffiniPay online payment collection (Phase 2)
# Put TEST keys in dev's config/.env and LIVE keys in prod's — same variable
# names per environment (AffiniPay test keys only touch test accounts). Leave
# PAYMENT_PROCESSOR=fake until the LawPay adapter is wired up, then set to lawpay.
PAYMENT_PROCESSOR=fake
LAWPAY_PUBLIC_KEY=
LAWPAY_SECRET_KEY=
LAWPAY_OPERATING_ACCOUNT_ID=
# Override only if AffiniPay changes the host (defaults to https://api.8am.com).
# Leave this line OUT of config/.env to keep the default; an empty value wins.
# LAWPAY_API_BASE=

# Digital Ocean Storage Spaces
DIGITAL_OCEAN_REGION_NAME=[string]
DIGITAL_OCEAN_ENDPOINT_URL=[string]
DIGITAL_OCEAN_BUCKET_NAME=[string]
DIGITAL_OCEAN_ACCESS_KEY_ID=[string]
DIGITAL_OCEAN_SECRET_ACCESS_KEY=[string]
