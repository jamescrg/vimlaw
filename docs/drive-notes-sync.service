[Unit]
Description=Aletheia Google Drive case-notes sync (oneshot)
After=network.target

[Service]
Type=oneshot
User=<user>
Group=<user>
WorkingDirectory=/home/<user>/law
ExecStart=/home/<user>/law/.venv/bin/python manage.py sync_drive_notes

# Notes:
# - Django loads config/.env itself (settings.read_env), so no EnvironmentFile
#   is needed. pandoc must be on PATH (default /usr/bin/pandoc is fine).
# - This is the incremental sync. It no-ops cleanly until an admin links a
#   Drive account at /settings/integrations/.
# - Driven by drive-notes-sync.timer (every ~30s). The oneshot type means the
#   timer naturally waits for the previous run to finish before starting another.
# - Schedule a nightly `--full` run separately to reconcile folder renames/moves,
#   which the incremental changes feed does not re-path on its own, e.g.:
#     ExecStart=... manage.py sync_drive_notes --full
#   in a second timer set to OnCalendar=*-*-* 03:00:00
